{
  "name": "incident-simulator",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n ui,api -c blue,green \"vite\" \"node --env-file=.env server/index.js\"",
    "dev:ui": "vite",
    "dev:api": "node --env-file=.env server/index.js",
    "build": "vite build",
    "qa": "node scripts/qa-validate.mjs",
    "start": "NODE_ENV=production node --env-file=.env server/index.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.1.1",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.3",
    "concurrently": "^9.1.2"
  }
}
